msgid "TEXT_REVIEW_COOKIES_LONG_LIVED"
msgstr "{0} cookies lever længere end et år"

msgid "TEXT_REVIEW_COOKIES_NOT_SECURE"
msgstr "{0} cookies mangler attributten Secure"

msgid "TEXT_REVIEW_THIRD_PARTY_VERY_GOOD"
msgstr "- Der laves ingen kald til tredjepart"

msgid "TEXT_REVIEW_THIRD_PARTY_REQUESTS"
msgstr "der laves kald til {0} tredjepartsdomæner"

msgid "TEXT_REVIEW_THIRD_PARTY_TRACKERS"
msgstr "{0} kendte sporingsdomæner kontaktes"

