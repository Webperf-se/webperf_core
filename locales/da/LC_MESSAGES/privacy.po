msgstr "Kunne ikke nå webbkoll-backend-tjenesten på {0}\n"

msgid "TEXT_REVIEW_VERY_GOOD"
msgstr "- Webstedet er rigtig godt til privatliv!\n"

msgid "TEXT_REVIEW_IS_GOOD"
msgstr "- Webstedet kunne være bedre, men er ret godt.\n"

msgid "TEXT_REVIEW_IS_OK"
msgstr "- Omtrent gennemsnitligt privatliv, men bør blive bedre.\n"

msgid "TEXT_REVIEW_IS_BAD"
msgstr "- Ret dårligt privatliv.\n"

msgid "TEXT_REVIEW_IS_VERY_BAD"
msgstr "- Meget dårligt privatliv for brugerne!\n"

msgid "TEXT_REVIEW_HTTPS_VERY_GOOD"
msgstr "- HTTPS bruges og der laves ingen usikre kald"

msgid "TEXT_REVIEW_HTTPS_NO_HTTPS"
msgstr "webstedet bruger ikke HTTPS"

msgid "TEXT_REVIEW_HTTPS_MIXED_CONTENT"
msgstr "{0} ressourcer indlæses over usikker HTTP (mixed content)"

msgid "TEXT_REVIEW_HTTPS_OLD_TLS"
msgstr "en forældet TLS-version bruges ({0})"

msgid "TEXT_REVIEW_REFERRER_POLICY_VERY_GOOD"
msgstr "- Referrer-politikken beskytter dine besøgende ({0})"

msgid "TEXT_REVIEW_REFERRER_POLICY_MISSING"
msgstr "ingen referrer-politik er sat, browsere kan lække besøgte adresser til andre websteder"

