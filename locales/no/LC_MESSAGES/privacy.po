msgstr "Kunne ikke nå webbkoll-backend-tjenesten på {0}\n"

msgid "TEXT_REVIEW_VERY_GOOD"
msgstr "- Nettstedet er veldig bra på personvern!\n"

msgid "TEXT_REVIEW_IS_GOOD"
msgstr "- Nettstedet kunne vært bedre, men er ganske bra.\n"

msgid "TEXT_REVIEW_IS_OK"
msgstr "- Omtrent gjennomsnittlig personvern, men bør bli bedre.\n"

msgid "TEXT_REVIEW_IS_BAD"
msgstr "- Ganske dårlig personvern.\n"

msgid "TEXT_REVIEW_IS_VERY_BAD"
msgstr "- Veldig dårlig personvern for brukerne!\n"

msgid "TEXT_REVIEW_HTTPS_VERY_GOOD"
msgstr "- HTTPS brukes og ingen usikre kall gjøres"

msgid "TEXT_REVIEW_HTTPS_NO_HTTPS"
msgstr "nettstedet bruker ikke HTTPS"

msgid "TEXT_REVIEW_HTTPS_MIXED_CONTENT"
msgstr "{0} ressurser lastes over usikker HTTP (mixed content)"

msgid "TEXT_REVIEW_HTTPS_OLD_TLS"
msgstr "en utdatert TLS-versjon brukes ({0})"

msgid "TEXT_REVIEW_REFERRER_POLICY_VERY_GOOD"
msgstr "- Referrer-policyen beskytter dine besøkende ({0})"

msgid "TEXT_REVIEW_REFERRER_POLICY_MISSING"
msgstr "ingen referrer-policy er satt, nettlesere kan lekke besøkte adresser til andre nettsteder"

