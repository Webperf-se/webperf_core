msgstr "{0} informasjonskapsler lever lenger enn ett år"

msgid "TEXT_REVIEW_COOKIES_NOT_SECURE"
msgstr "{0} informasjonskapsler mangler attributtet Secure"

msgid "TEXT_REVIEW_THIRD_PARTY_VERY_GOOD"
msgstr "- Ingen kall gjøres til tredjepart"

msgid "TEXT_REVIEW_THIRD_PARTY_REQUESTS"
